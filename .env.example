PROJECT_NAME=billflow

# Server
PORT=8090
ENV=development

# Database
DATABASE_URL=postgres://billflow:changeme_strong_password@localhost:5438/billflow
DB_USER=billflow
DB_PASSWORD=changeme_strong_password

# JWT (min 32 chars)
JWT_SECRET=your-secret-key-must-be-at-least-32-characters
JWT_EXPIRE_HOURS=24

# LINE OA — REISSUE token/secret ก่อนใช้ทุกครั้ง (Messaging API → Reissue)
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=
LINE_ADMIN_USER_ID=

# Email IMAP
# Gmail: imap.gmail.com:993 + App Password 16 หลัก (ต้องเปิด 2-Step Verification ก่อน)
# Outlook: imap-mail.outlook.com:993
# ⚠️ IMAP_POLL_INTERVAL ห้ามน้อยกว่า 5m — Gmail rate limit จะคืน "unexpected EOF"
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=billing@company.com
IMAP_PASSWORD=
IMAP_FILTER_FROM=
IMAP_FILTER_SUBJECT=PO,Purchase Order,ใบสั่งซื้อ,ถูกจัดส่งแล้ว
IMAP_POLL_INTERVAL=5m

# Shopee email auto-detection (comma-separated domain suffixes)
SHOPEE_EMAIL_DOMAINS=shopee.co.th,mail.shopee.co.th,noreply.shopee.co.th

# OpenRouter (text/image/PDF/audio)
OPENROUTER_API_KEY=sk-or-xxx
OPENROUTER_MODEL=google/gemini-2.5-flash
OPENROUTER_FALLBACK_MODEL=google/gemini-flash-1.5
OPENROUTER_AUDIO_MODEL=openai/whisper-1

# Mistral OCR — ต้องตั้ง ไม่งั้น PDF extraction พังเงียบ (model: mistral-ocr-2512)
MISTRAL_API_KEY=

# SML #1 — JSON-RPC (LINE OA + Email)
SML_BASE_URL=http://192.168.2.213:3248

# SML #2 — REST saleinvoice (Shopee Excel import)
# ⚠️ SHOPEE_SML_UNIT_CODE ห้ามว่าง — SML reject unit_code=""
# ⚠️ SHOPEE_SML_BRANCH_CODE ต้องตรงกับ fiscal period ใน SML
# ค่าที่ confirmed working (2026-04-24): GUID=smlx PROVIDER=SMLGOH DB=SML1_2026
SHOPEE_SML_URL=http://192.168.2.248:8080
SHOPEE_SML_GUID=smlx
SHOPEE_SML_PROVIDER=SMLGOH
SHOPEE_SML_CONFIG_FILE=SMLConfigSMLGOH.xml
SHOPEE_SML_DATABASE=SML1_2026
SHOPEE_SML_BRANCH_CODE=001
SHOPEE_SML_DOC_FORMAT=INV
SHOPEE_SML_CUST_CODE=AR00004
SHOPEE_SML_SALE_CODE=
SHOPEE_SML_WH_CODE=WH-01
SHOPEE_SML_SHELF_CODE=SH-01
SHOPEE_SML_UNIT_CODE=ถุง
SHOPEE_SML_VAT_TYPE=0
SHOPEE_SML_VAT_RATE=7
SHOPEE_SML_DOC_TIME=09:00

# Shopee shipped email → SML purchaseorder (reuses all SHOPEE_SML_* above)
# Only doc_format and cust_code differ. cust_code falls back to SHOPEE_SML_CUST_CODE if blank.
# ⚠️ For shipped emails to flow through IMAP, IMAP_FILTER_SUBJECT must include "ถูกจัดส่งแล้ว"
SHIPPED_SML_DOC_FORMAT=PO
SHIPPED_SML_CUST_CODE=

# Auto-confirm threshold (final_confidence ≥ X AND no block AND warns ≤ 1)
AUTO_CONFIRM_THRESHOLD=0.85

# Cron
INSIGHT_CRON_HOUR=8
BACKUP_CRON_HOUR=0
INSIGHT_LINE_NOTIFY=true
DISK_WARN_PERCENT=90

# Frontend (Vite build-time)
VITE_API_URL=http://localhost:8090
