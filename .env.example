PROJECT_NAME=billflow

# Server
PORT=8090
ENV=development

# Database
DATABASE_URL=postgres://billflow:changeme_strong_password@localhost:5438/billflow
DB_USER=billflow
DB_PASSWORD=changeme_strong_password

# JWT
JWT_SECRET=your-secret-key-must-be-at-least-32-characters
JWT_EXPIRE_HOURS=24

# LINE OA — REISSUE ก่อนใช้ทุกครั้ง
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=
LINE_ADMIN_USER_ID=

# Email IMAP
IMAP_HOST=mail.company.com
IMAP_PORT=993
IMAP_USER=billing@company.com
IMAP_PASSWORD=
IMAP_FILTER_FROM=vendor@company.com
IMAP_FILTER_SUBJECT=PO,Purchase Order,ใบสั่งซื้อ
IMAP_POLL_INTERVAL=5m

# OpenRouter
OPENROUTER_API_KEY=sk-or-xxx
OPENROUTER_MODEL=google/gemini-flash-1.5
OPENROUTER_FALLBACK_MODEL=anthropic/claude-haiku-3
OPENROUTER_AUDIO_MODEL=openai/whisper-1

# SML ERP — Sale Order REST API v2
SML_BASE_URL=http://192.168.2.213:3248
SML_GUID=SMLX
SML_PROVIDER=               # ชื่อผู้ใช้บริการ
SML_CONFIG_FILE=            # ชื่อ config file บน SML server e.g. SMLConfig.xml
SML_DATABASE_NAME=          # ชื่อฐานข้อมูล SML
SML_DOC_FORMAT_CODE=SO      # รหัสรูปแบบเอกสาร ใบสั่งขาย
SML_SALE_CODE=              # รหัสพนักงานขาย (optional)
SML_CUST_CODE=CASH          # รหัสลูกค้า default สำหรับลูกค้าทั่วไป
SML_WH_CODE=                # รหัสคลัง
SML_SHELF_CODE=             # รหัสชั้นวาง
SML_UNIT_CODE=              # หน่วย fallback กรณีสินค้าไม่มีหน่วย
SML_VAT_TYPE=0              # 0=แยกนอก, 1=รวมใน, 2=ศูนย์%
SML_VAT_RATE=7              # อัตรา VAT %

# Shopee SML — saleinvoice REST API (SML 224 — different server)
SHOPEE_SML_URL=http://192.168.2.248:8080
SHOPEE_SML_GUID=SMLX
SHOPEE_SML_PROVIDER=SML1
SHOPEE_SML_CONFIG_FILE=SMLConfigSML1.xml
SHOPEE_SML_DATABASE=SMLPLOY
SHOPEE_SML_DOC_FORMAT=IV
SHOPEE_SML_CUST_CODE=
SHOPEE_SML_SALE_CODE=
SHOPEE_SML_WH_CODE=
SHOPEE_SML_SHELF_CODE=
SHOPEE_SML_UNIT_CODE=
SHOPEE_SML_VAT_TYPE=0
SHOPEE_SML_VAT_RATE=7
SHOPEE_SML_DOC_TIME=09:00

# Auto-confirm threshold
AUTO_CONFIRM_THRESHOLD=0.85

# Cron
INSIGHT_CRON_HOUR=8
BACKUP_CRON_HOUR=0
INSIGHT_LINE_NOTIFY=true
DISK_WARN_PERCENT=90

# Frontend (used by Vite at build time)
VITE_API_URL=http://localhost:8090
